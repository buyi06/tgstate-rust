# [Required] Telegram Bot Token from @BotFather
BOT_TOKEN=your_telegram_bot_token

# [Required] File storage channel/group
# Can be public channel username (@channel_name) or private channel ID (-100123456789)
CHANNEL_NAME=@your_telegram_channel_or_your_id

# [Optional] Web interface password
# Leave empty for no login required
PASS_WORD=your_secret_password

# [Optional] PicGo API upload key
PICGO_API_KEY=your_picgo_api_key

# [Optional] Public access URL
# Used for generating share links. Auto-detected from request Host if empty
BASE_URL=http://127.0.0.1:8000

# [Optional] Run mode (default "p")
# "p" = public mode, "m" = private mode
MODE=p

# [Optional] Log level
LOG_LEVEL=info

# [Optional] Data directory (usually /app/data in Docker)
DATA_DIR=app/data
